<?xml version="1.0"?>
<pfsense>
	<version>24.0</version>
	<lastchange></lastchange>
	<system>
		<optimization>normal</optimization>
		<hostname>pfSense</hostname>
		<domain>home.arpa</domain>
		<dnsallowoverride></dnsallowoverride>
		<group>
			<name>all</name>
			<description><![CDATA[All Users]]></description>
			<scope>system</scope>
			<gid>1998</gid>
			<member>0</member>
		</group>
		<group>
			<name>admins</name>
			<description><![CDATA[System Administrators]]></description>
			<scope>system</scope>
			<gid>1999</gid>
			<member>0</member>
			<priv>page-all</priv>
		</group>
		<user>
			<name>admin</name>
			<descr><![CDATA[System Administrator]]></descr>
			<scope>system</scope>
			<groupname>admins</groupname>
			<uid>0</uid>
			<priv>user-shell-access</priv>
			<!-- bcrypt-hash removed before publishing -->
		</user>
		<nextuid>2000</nextuid>
		<nextgid>2000</nextgid>
		<timeservers>2.pfsense.pool.ntp.org</timeservers>
		<webgui>
			<protocol>https</protocol>
			<!-- ssl-certref removed before publishing -->
			<dashboardcolumns>2</dashboardcolumns>
			<port>443</port>
			<max_procs>2</max_procs>
			<roaming>disabled</roaming>
		</webgui>
		<disablenatreflection>yes</disablenatreflection>
		<disablesegmentationoffloading></disablesegmentationoffloading>
		<disablelargereceiveoffloading></disablelargereceiveoffloading>
		<ipv6allow></ipv6allow>
		<maximumtableentries>400000</maximumtableentries>
		<powerd_ac_mode>hadp</powerd_ac_mode>
		<powerd_battery_mode>hadp</powerd_battery_mode>
		<powerd_normal_mode>hadp</powerd_normal_mode>
		<bogons>
			<interval>monthly</interval>
		</bogons>
		<hn_altq_enable></hn_altq_enable>
		<dnsserver>8.8.4.4</dnsserver>
		<dnsserver>8.8.8.8</dnsserver>
		<timezone>Etc/UTC</timezone>
		<serialspeed>115200</serialspeed>
		<primaryconsole>video</primaryconsole>
		<sshguard_threshold>10</sshguard_threshold>
		<sshguard_blocktime>120</sshguard_blocktime>
		<sshguard_detection_time>600</sshguard_detection_time>
	</system>
	<interfaces>
		<wan>
			<enable></enable>
			<if>em0</if>
			<ipaddr>dhcp</ipaddr>
			<ipaddrv6></ipaddrv6>
			<gateway></gateway>
			<blockpriv></blockpriv>
			<blockbogons></blockbogons>
			<media></media>
			<mediaopt></mediaopt>
			<dhcp6-duid></dhcp6-duid>
			<dhcp6-ia-pd-len>0</dhcp6-ia-pd-len>
			<subnetv6></subnetv6>
			<gatewayv6></gatewayv6>
		</wan>
		<lan>
			<enable></enable>
			<if>em1</if>
			<ipaddr>192.168.10.1</ipaddr>
			<subnet>24</subnet>
			<subnetv6></subnetv6>
			<media></media>
			<mediaopt></mediaopt>
			<track6-interface>wan</track6-interface>
			<track6-prefix-id>0</track6-prefix-id>
			<gateway></gateway>
			<ipaddrv6></ipaddrv6>
			<gatewayv6></gatewayv6>
		</lan>
		<opt1>
			<if>em2</if>
			<descr><![CDATA[WLAN]]></descr>
			<enable></enable>
			<ipaddr>192.168.20.1</ipaddr>
			<subnet>24</subnet>
			<spoofmac></spoofmac>
		</opt1>
	</interfaces>
	<staticroutes></staticroutes>
	<dhcpd>
		<lan>
			<range>
				<from>192.168.10.100</from>
				<to>192.168.10.200</to>
			</range>
			<enable></enable>
		</lan>
		<opt1>
			<enable></enable>
			<range>
				<from>192.168.20.100</from>
				<to>192.168.20.200</to>
			</range>
		</opt1>
	</dhcpd>
	<nat>
		<outbound>
			<mode>automatic</mode>
		</outbound>
	</nat>
	<filter>
		<!-- ======================== LAN RULES ======================== -->
		<rule>
			<type>pass</type>
			<interface>lan</interface>
			<ipprotocol>inet</ipprotocol>
			<protocol>tcp/udp</protocol>
			<source>
				<network>lan</network>
			</source>
			<destination>
				<address>192.168.10.1</address>
				<port>53</port>
			</destination>
			<log></log>
			<descr><![CDATA[Allow LAN DNS]]></descr>
		</rule>
		<rule>
			<type>pass</type>
			<interface>lan</interface>
			<ipprotocol>inet</ipprotocol>
			<protocol>tcp</protocol>
			<source>
				<network>lan</network>
			</source>
			<destination>
				<any></any>
				<port>80</port>
			</destination>
			<log></log>
			<descr><![CDATA[Allow LAN internet browsing]]></descr>
		</rule>
		<rule>
			<type>pass</type>
			<interface>lan</interface>
			<ipprotocol>inet</ipprotocol>
			<protocol>tcp</protocol>
			<source>
				<network>lan</network>
			</source>
			<destination>
				<address>192.168.10.1</address>
				<port>443</port>
			</destination>
			<log></log>
			<descr><![CDATA[Allow LAN access to pfSense WebGUI]]></descr>
		</rule>
		<rule>
			<type>block</type>
			<interface>lan</interface>
			<ipprotocol>inet46</ipprotocol>
			<source>
				<any></any>
			</source>
			<destination>
				<any></any>
			</destination>
			<log></log>
			<descr><![CDATA[Default Deny All]]></descr>
		</rule>
		<!-- ======================== WLAN RULES ======================== -->
		<rule>
			<type>pass</type>
			<interface>opt1</interface>
			<ipprotocol>inet</ipprotocol>
			<protocol>udp</protocol>
			<source>
				<network>opt1</network>
			</source>
			<destination>
				<any></any>
				<port>53</port>
			</destination>
			<log></log>
			<descr><![CDATA[Allow WLAN DNS resolution]]></descr>
		</rule>
		<rule>
			<type>block</type>
			<interface>opt1</interface>
			<ipprotocol>inet</ipprotocol>
			<source>
				<network>opt1</network>
			</source>
			<destination>
				<address>192.168.10.0/24</address>
			</destination>
			<log></log>
			<descr><![CDATA[Block WLAN to LAN - Lateral movement]]></descr>
		</rule>
		<rule>
			<type>block</type>
			<interface>opt1</interface>
			<ipprotocol>inet</ipprotocol>
			<protocol>tcp</protocol>
			<source>
				<network>opt1</network>
			</source>
			<destination>
				<network>opt1ip</network>
				<port>80</port>
			</destination>
			<log></log>
			<descr><![CDATA[Block WLAN access to pfSense WebGUI]]></descr>
		</rule>
		<rule>
			<type>block</type>
			<interface>opt1</interface>
			<ipprotocol>inet</ipprotocol>
			<source>
				<network>opt1</network>
			</source>
			<destination>
				<address>10.0.0.0/8</address>
			</destination>
			<log></log>
			<descr><![CDATA[Block WLAN to RFC1918 Class A]]></descr>
		</rule>
		<rule>
			<type>block</type>
			<interface>opt1</interface>
			<ipprotocol>inet</ipprotocol>
			<source>
				<any></any>
			</source>
			<destination>
				<address>172.16.0.0/12</address>
			</destination>
			<log></log>
			<descr><![CDATA[Block WLAN to RFC1918 Class B]]></descr>
		</rule>
		<rule>
			<type>pass</type>
			<interface>opt1</interface>
			<ipprotocol>inet</ipprotocol>
			<protocol>tcp</protocol>
			<source>
				<network>opt1</network>
			</source>
			<destination>
				<any></any>
				<port>80-443</port>
			</destination>
			<log></log>
			<descr><![CDATA[Allow WLAN internet browsing only]]></descr>
		</rule>
		<rule>
			<type>block</type>
			<interface>opt1</interface>
			<ipprotocol>inet</ipprotocol>
			<source>
				<any></any>
			</source>
			<destination>
				<any></any>
			</destination>
			<log></log>
			<descr><![CDATA[Default Deny All]]></descr>
		</rule>
	</filter>
	<!-- SSL certificate removed before publishing -->
	<gateways>
		<gateway_item>
			<interface>wan</interface>
			<gateway>dynamic</gateway>
			<name>WAN_DHCP</name>
			<weight>1</weight>
			<ipprotocol>inet</ipprotocol>
			<descr><![CDATA[Interface WAN_DHCP Gateway]]></descr>
		</gateway_item>
	</gateways>
</pfsense>
